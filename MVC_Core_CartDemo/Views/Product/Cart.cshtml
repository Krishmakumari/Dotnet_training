@{
}

@model List<MVC_Core_CartDemo.Models.Product>

<h2>My Cart</h2>

@{
    int total = 0;
}

@foreach (var item in Model)
{
    <p>@item.Name - ₹@item.Price</p>
    total += item.Price;
}

<h3>Total: ₹@total</h3>

<h4>Items Count: @Model.Count</h4>