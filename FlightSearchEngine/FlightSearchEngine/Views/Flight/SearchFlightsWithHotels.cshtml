@model IEnumerable<FlightSearchEngine.Models.FlightHotelResult>

@{
    ViewData["Title"] = "Flight + Hotel Search Results";
}

<h2>Flight + Hotel Search Results</h2>

@if (Model != null && Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Flight ID</th>
                <th>Flight Name</th>
                <th>Source</th>
                <th>Destination</th>
                <th>Hotel Name</th>
                <th>Total Cost</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FlightId</td>
                    <td>@item.FlightName</td>
                    <td>@item.Source</td>
                    <td>@item.Destination</td>
                    <td>@item.HotelName</td>
                    <td>@item.TotalCost</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No results found.</p>
}

<a asp-action="Index">Back to Search</a>
