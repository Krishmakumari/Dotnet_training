@model IEnumerable<StudentMngmentSystem.Models.Department>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
    <a asp-controller="TeacherDashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.DepartmentId</td>
            <td>@item.DepartmentName</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-secondary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
