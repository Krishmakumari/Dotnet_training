@model StudentMngmentSystem.ViewModels.StudentProfileViewModel

<h2>Student Profile</h2>

@if (Model == null)
{
    <div class="alert alert-warning">Student record not found. Please ask your teacher to add your student record.</div>
    <a asp-controller="StudentDashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
}
else
{
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Name:</strong> @Model.StudentName</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Department:</strong> @Model.DepartmentName</p>
            <p><strong>Course:</strong> @Model.CourseName</p>
        </div>
    </div>

    <h4>Update Contact Info</h4>
    <form asp-action="Profile" method="post">
        <input type="hidden" asp-for="StudentId" />
        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-controller="StudentDashboard" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
}
