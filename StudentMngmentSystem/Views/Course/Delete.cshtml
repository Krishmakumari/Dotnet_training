@model StudentMngmentSystem.Models.Course

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.CourseId</dd>
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.CourseName</dd>
        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department?.DepartmentName</dd>
    </dl>
</div>
<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="CourseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
<a asp-action="Index" asp-controller="Course" class="btn btn-secondary mt-2">Back to List</a>
