@model StudentMngmentSystem.Models.Course

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="CourseName" class="form-label"></label>
        <input asp-for="CourseName" class="form-control" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Duration" class="form-label"></label>
        <input asp-for="Duration" class="form-control" />
        <span asp-validation-for="Duration" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Fees" class="form-label"></label>
        <input asp-for="Fees" class="form-control" />
        <span asp-validation-for="Fees" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DepartmentId" class="form-label"></label>
        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId"></select>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>
<a asp-action="Index" asp-controller="Course" class="btn btn-secondary mt-2">Back to List</a>
